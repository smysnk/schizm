{
  "name": "schizm",
  "private": true,
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "aws:create-ecr": "./scripts/create-ecr-repositories.sh",
    "docker:build": "docker build -f docker/Dockerfile -t schizm:local .",
    "dev": "./scripts/mono-helper.sh dev mono-helper.yml",
    "build": "yarn workspaces foreach -A -t run build",
    "start": "./scripts/mono-helper.sh env yarn workspaces foreach -A -p -i run start",
    "sync:prompt-audit": "yarn workspace server exec tsx ../../scripts/sync-prompt-audit.ts",
    "battletest:run": "yarn workspace server exec tsx ../../scripts/run-program-battletest.ts",
    "battletest:evaluate": "yarn workspace server exec tsx ../../scripts/evaluate-program-battletest.ts",
    "battletest:report": "yarn workspace server exec tsx ../../scripts/report-program-battletest-suite.ts",
    "battletest:suite": "yarn workspace server exec tsx ../../scripts/run-program-battletest-suite.ts",
    "dev:web": "./scripts/mono-helper.sh env yarn workspace web dev",
    "build:web": "yarn workspace web build",
    "start:web": "./scripts/mono-helper.sh env yarn workspace web start",
    "dev:server": "./scripts/mono-helper.sh env yarn workspace server dev",
    "build:server": "yarn workspace server build",
    "start:server": "./scripts/mono-helper.sh env yarn workspace server start",
    "migrate": "./scripts/mono-helper.sh env yarn workspace server migrate",
    "fleet:env-secret": "./scripts/apply-fleet-env-secret.sh",
    "fleet:gitrepo-secret": "./scripts/apply-fleet-gitrepo-ssh-secret.sh",
    "fleet:kubeconfig": "./scripts/create-fleet-kubeconfig.sh",
    "fleet:deploy": "./scripts/deploy-fleet.sh",
    "fleet:lint": "helm lint ./fleet/schizm",
    "fleet:monitor": "./scripts/monitor-deployment-output.sh",
    "fleet:recycle": "./scripts/recycle-and-monitor.sh",
    "fleet:template": "helm template schizm ./fleet/schizm --values ./fleet/schizm/values.yaml",
    "test": "test-station run --config ./test-station.config.mjs",
    "test:coverage": "test-station run --config ./test-station.config.mjs --coverage",
    "test:fast": "test-station run --config ./test-station.config.mjs --no-coverage",
    "test:server": "yarn workspace server test",
    "test:battletest:report": "yarn workspace server exec tsx ../../scripts/generate-program-battletest-test-station-report.ts",
    "test:demo": "python3 -m unittest discover -s docs/demo -p 'test_*.py'",
    "test:e2e": "playwright test",
    "test:report:publish": "node ./scripts/publish-ingest-report.mjs --input ./.test-results/schizm-test-report/report.json"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@test-station/cli": "^0.2.22"
  }
}
