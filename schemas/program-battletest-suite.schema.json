{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schizm.local/schemas/program-battletest-suite.schema.json",
  "title": "ProgramBattleTestSuite",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "title",
    "description",
    "tags",
    "scenarios"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
