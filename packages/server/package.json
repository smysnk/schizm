{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format cjs --target node20 --out-dir dist --clean",
    "start": "node dist/index.js",
    "migrate": "tsx src/index.ts --migrate-only",
    "test": "tsx --test src/**/*.test.ts",
    "test:battletest": "node --import tsx --test src/services/program-battletest/scenario-pack.test.ts src/services/program-battletest/harness.test.ts src/services/program-battletest/evaluator.test.ts src/services/program-battletest/suite.test.ts src/services/program-battletest/reporting.test.ts",
    "test:battletest-harness": "node --import tsx --test src/services/program-battletest/harness.test.ts",
    "test:battletest-evaluator": "node --import tsx --test src/services/program-battletest/evaluator.test.ts",
    "test:battletest-suite": "node --import tsx --test src/services/program-battletest/suite.test.ts",
    "test:battletest-reporting": "node --import tsx --test src/services/program-battletest/reporting.test.ts",
    "test:canvas": "node --import tsx --test src/services/canvas-validator.test.ts",
    "test:git-worktree": "node --import tsx --test src/services/git-worktree.test.ts"
  },
  "dependencies": {
    "@apollo/server": "^4.10.0",
    "@graphql-tools/schema": "^10.0.25",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "graphql": "^16.8.1",
    "graphql-ws": "^5.16.2",
    "pg": "^8.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
    "@types/ws": "^8.5.13",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
